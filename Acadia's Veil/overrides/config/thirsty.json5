		"dirtyThirstEffectChance": 0.30000001192092896,
		// The duration of the Thirst Effect gained from a DIRTY Water Canteen in ticks (1sec = 20ticks).
		"dirtyThirstEffectDurationTicks": 300,
		// The amount of uses Water Canteen items should have.
		"maxUses": 12
	},
	"waterItemSettings": {
